{
  "name": "ixrail-agentpay",
  "displayName": "ixrail AgentPay",
  "description": "Give AI agents, MCP servers, and agent frameworks a wallet, a budget, and governed x402 payment rails right from VS Code.",
  "version": "0.2.6",
  "publisher": "ixrail",
  "license": "MIT",
  "homepage": "https://ixrail.com",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#05070d",
    "theme": "dark"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "AI"],
  "keywords": ["ai agents", "payments", "x402", "wallet", "mcp", "agent payments", "stablecoin", "usdc"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "ixrail AgentPay",
      "properties": {
        "ixrail.simulateSettlement": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Simulate on-chain settlement for **sandbox (Base Sepolia)** wallets so the full pay -> receipt loop works locally without faucet funds. Turn this off to broadcast real testnet transactions (requires a funded wallet). Mainnet wallets always settle on-chain."
        },
        "ixrail.brokerPort": {
          "type": "number",
          "default": 4022,
          "minimum": 1,
          "maximum": 65535,
          "markdownDescription": "Localhost port used by the AgentPay broker. Environment variable `IXRAIL_HTTP_PORT` takes precedence."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ixrail-agentpay",
          "title": "ixrail AgentPay",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ixrail-agentpay": [
        {
          "type": "webview",
          "id": "ixrail.sidebar",
          "name": "AgentPay"
        }
      ]
    },
    "commands": [
      { "command": "ixrail.createWallet", "category": "ixrail AgentPay", "title": "Create Agent Wallet" },
      { "command": "ixrail.setBudget", "category": "ixrail AgentPay", "title": "Set Spending Policy" },
      { "command": "ixrail.payX402", "category": "ixrail AgentPay", "title": "Pay x402 Endpoint" },
      { "command": "ixrail.verifyReceipt", "category": "ixrail AgentPay", "title": "Verify Receipt Signature" },
      { "command": "ixrail.startBroker", "category": "ixrail AgentPay", "title": "Start Local Broker" },
      { "command": "ixrail.stopBroker", "category": "ixrail AgentPay", "title": "Stop Local Broker" },
      { "command": "ixrail.startMerchant", "category": "ixrail AgentPay", "title": "Start Sandbox Merchant" },
      { "command": "ixrail.stopMerchant", "category": "ixrail AgentPay", "title": "Stop Sandbox Merchant" },
      { "command": "ixrail.copyMcpConfig", "category": "ixrail AgentPay", "title": "Copy MCP Configuration" },
      { "command": "ixrail.openWebsite", "category": "ixrail AgentPay", "title": "Open ixrail Website" },
      { "command": "ixrail.revokeAgent", "category": "ixrail AgentPay", "title": "Revoke Agent Access" },
      { "command": "ixrail.restoreAgent", "category": "ixrail AgentPay", "title": "Restore Agent Access" },
      { "command": "ixrail.refresh", "category": "ixrail AgentPay", "title": "Refresh", "icon": "$(refresh)" },
      { "command": "ixrail.runDemo", "category": "ixrail AgentPay", "title": "Set Up Sandbox Demo" },
      { "command": "ixrail.viewReceipts", "category": "ixrail AgentPay", "title": "View Receipt Ledger", "icon": "$(list-flat)" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "ixrail.createWallet", "when": "true" },
        { "command": "ixrail.payX402", "when": "true" },
        { "command": "ixrail.viewReceipts", "when": "true" },
        { "command": "ixrail.startBroker", "when": "true" },
        { "command": "ixrail.stopBroker", "when": "true" },
        { "command": "ixrail.startMerchant", "when": "true" },
        { "command": "ixrail.copyMcpConfig", "when": "true" },
        { "command": "ixrail.openWebsite", "when": "true" },
        { "command": "ixrail.runDemo", "when": "true" }
      ],
      "view/title": [
        { "command": "ixrail.refresh", "when": "view == ixrail.sidebar", "group": "navigation@1" },
        { "command": "ixrail.viewReceipts", "when": "view == ixrail.sidebar", "group": "navigation@2" }
      ]
    },
    "viewsWelcome": [
      {
        "view": "ixrail.sidebar",
        "contents": "Create a governed sandbox wallet to begin.\n[Create Agent Wallet](command:ixrail.createWallet)\n[Set Up Guided Demo](command:ixrail.runDemo)"
      }
    ],
    "walkthroughs": [
      {
        "id": "ixrail.agentpay.gettingStarted",
        "title": "Get started with ixrail AgentPay",
        "description": "Give an agent a wallet, spending policy, and local payment rail.",
        "steps": [
          {
            "id": "ixrail.agentpay.createWallet",
            "title": "Create a sandbox wallet",
            "description": "Create a Base Sepolia wallet for an agent.",
            "media": { "image": "media/icon.png", "altText": "ixrail AgentPay mark" },
            "completionEvents": ["onCommand:ixrail.createWallet"]
          },
          {
            "id": "ixrail.agentpay.setPolicy",
            "title": "Set spending controls",
            "description": "Define transaction, daily, monthly, approval, and merchant controls.",
            "media": { "image": "media/icon.png", "altText": "ixrail AgentPay mark" },
            "completionEvents": ["onCommand:ixrail.setBudget"]
          },
          {
            "id": "ixrail.agentpay.startBroker",
            "title": "Start the local broker",
            "description": "Expose AgentPay tools to local agents over an authenticated localhost endpoint.",
            "media": { "image": "media/icon.png", "altText": "ixrail AgentPay mark" },
            "completionEvents": ["onCommand:ixrail.startBroker"]
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "npm run bundle-extension",
    "typecheck": "tsc -p ./ --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile": "tsc -p ./",
    "bundle-extension": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "npm run build",
    "package": "npx --yes @vscode/vsce package --no-dependencies --allow-missing-repository",
    "mcp-server": "node out/mcp/server.js",
    "http-bridge": "node out/mcp/httpBridge.js",
    "mock-merchant": "node out/mock-merchant/server.js"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.3",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "supertest": "^7.1.1",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "ethers": "^6.11.0",
    "express": "^4.19.0"
  }
}
